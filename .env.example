# ===========================================
# Learning Helper Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# Node Service Configuration
# -------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Python LLM Service
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_TOKEN=your-internal-service-token

# Database
DATABASE_URL=postgresql://learning_helper:learning_helper_dev@localhost:5432/learning_helper

# Redis (required)
REDIS_URL=redis://localhost:6379

# YouTube API
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CACHE_TTL_SECONDS=604800

# OAuth (Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT
JWT_SECRET=your-32-character-or-longer-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -------------------------------------------
# Python Service Configuration
# -------------------------------------------
ENVIRONMENT=development
PYTHON_PORT=8000
PYTHON_LOG_LEVEL=info

# Service-to-service authentication
# Same token used by both services for internal communication
SERVICE_TOKEN=your-internal-service-token

# LLM Provider
LLM_PROVIDER=gemini
LLM_MODEL=LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE_PLAN=0.7
LLM_TEMPERATURE_EXERCISE=0.8
LLM_TEMPERATURE_GRADE=0.3

# API Keys
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Retry Configuration
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=30

BRAVE_SEARCH_API_KEY=your-brave-api-key
WEB_SEARCH_ENABLED=true
