# ===========================================
# Lucubrum Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# Node Service Configuration
# -------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Mastery
EXERCISE_MASTERY_CAP=0.35
MASTERY_VOLUME_TARGET=15

# Python LLM Service
PYTHON_SERVICE_URL=http://localhost:8000
# Render private services can provide host:port here instead of PYTHON_SERVICE_URL.
PYTHON_SERVICE_HOSTPORT=

# Database
DATABASE_URL=postgresql://lucubrum:lucubrum_dev@localhost:5432/lucubrum
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_POOL_MAX=10

# Redis (required)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-secure-redis-password

# JSON schema contracts
# Leave blank locally; Docker/Render set this to /app/packages/contracts/schemas.
SCHEMAS_DIR=

# YouTube API
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CACHE_TTL_SECONDS=604800

# Learn Content Caching
LEARN_CACHE_TTL_SECONDS=86400
LEARN_PRELOAD_CONCURRENCY=2

# Video Validation
VIDEO_VALIDATION_ENABLED=true
VIDEO_MIN_RELEVANCE_SCORE=0.6
VIDEO_VALIDATION_CONCURRENCY=5

# OAuth (Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback

# OAuth (Facebook)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:5173/oauth/callback

# JWT
JWT_SECRET=your-32-character-or-longer-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie Auth
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY_HOPS=1

# -------------------------------------------
# Python Service Configuration
# -------------------------------------------
ENVIRONMENT=development
PYTHON_PORT=8000
PYTHON_LOG_LEVEL=info

# Service-to-service authentication
# Shared by Node orchestrator and Python curriculum service
SERVICE_TOKEN=your-internal-service-token

# LLM Provider
LLM_PROVIDER=zai
LLM_MODEL=glm-5.1
LLM_TEMPERATURE_PLAN=0.7
LLM_TEMPERATURE_EXERCISES=0.8
LLM_TEMPERATURE_GRADE=0.3
LLM_TEMPERATURE_VALIDATE=0.3
LLM_TEMPERATURE_READING_MATERIAL=0.5
LLM_TEMPERATURE_NORMALIZE=0.3
LLM_TEMPERATURE_QUERIES=0.7
LLM_TEMPERATURE_EXAM=0.7
LLM_TEMPERATURE_STALENESS=0.3
LLM_MAX_TOKENS_PLAN=

# API Keys
ZAI_API_KEY=your-zai-api-key
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Retry Configuration
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=100

BRAVE_SEARCH_API_KEY=your-brave-api-key
WEB_SEARCH_ENABLED=true

# Context7 API (documentation lookup for staleness detection)
CONTEXT7_API_KEY=your-context7-api-key
CONTEXT7_ENABLED=true

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
# Frontend env vars must use VITE_ prefix for client-side access
VITE_EXERCISE_MASTERY_CAP=0.35
# Leave blank for local Vite proxy / same-origin deployments.
# For Vercel, set this to the Render API origin, e.g. https://api.example.com.
VITE_API_BASE_URL=
VITE_APP_URL=http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_API_TIMEOUT_SECONDS=120

# -------------------------------------------
# Staleness Detection
# -------------------------------------------
# Threshold for contradiction rate that triggers cache invalidation
STALENESS_CONTRADICTION_THRESHOLD=0.10
# Minimum hours between staleness checks for a cached plan
STALENESS_CHECK_COOLDOWN_HOURS=24
# Cache TTL for staleness policies loaded from database (seconds)
STALENESS_POLICIES_CACHE_TTL=300

# -------------------------------------------
# Quality Signals (Background Job)
# -------------------------------------------
# Enable/disable daily quality signal aggregation
QUALITY_SIGNALS_ENABLED=true
# Cron schedule for quality signals job (default: daily at 2 AM)
QUALITY_SIGNALS_SCHEDULE="0 2 * * *"
# Minimum sample size before quality metrics trigger cache invalidation
QUALITY_SIGNALS_MIN_SAMPLE_SIZE=20

# -------------------------------------------
# Tier / Monetization
# -------------------------------------------
TIER_PRO_ROLE=pro
TIER_SUPER_ROLE=super
FREE_MAX_ACTIVE_PLANS=3
FREE_ALLOWED_PLAN_SIZES=basic,moderate
FREE_DAILY_LLM_ATTEMPTS=15
FREE_MAX_EXAMS_PER_NODE=2
FREE_EXERCISE_REGENERATIONS=0
FREE_PLAN_HISTORY_DAYS=30

# -------------------------------------------
# Postgres (used by docker-compose.prod.yml)
# -------------------------------------------
POSTGRES_USER=lucubrum
POSTGRES_PASSWORD=lucubrum_dev
POSTGRES_DB=lucubrum

# -------------------------------------------
# Infra Scripts
# -------------------------------------------
# Days to retain LLM audit log rows (db-prune.sh)
LLM_LOG_RETENTION_DAYS=90
# Number of database backup files to keep (db-backup.sh)
BACKUP_RETAIN_COUNT=7
# S3 bucket for backup uploads; leave empty to skip upload (db-backup.sh)
AWS_S3_BACKUP_BUCKET=
# Bearer token for the cache warm-up service account (cache-warm.sh)
WARMUP_USER_TOKEN=
