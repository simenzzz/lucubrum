# Vite
# Leave EMPTY for both local (Vite dev proxy) and Vercel. On Vercel the API is
# reached same-origin via vercel.json rewrites (proxying /auth, /api, /admin to
# the Render API), so the browser only talks to the app origin and auth cookies
# stay first-party. Only set this to an absolute API origin if you stop using
# the proxy and serve the API from its own sub-domain.
VITE_API_BASE_URL=
# Local default; production = the app origin, e.g. https://lucubrum.samibk.com
# NOTE: serve the app top-level on a custom (sub)domain via DNS — never inside
# an <iframe> on another domain (Google OAuth refuses to load framed and the
# auth cookies become blocked third-party cookies). See docs/DEPLOYMENT.md.
VITE_APP_URL=http://localhost:5173

# API Timeout
VITE_API_TIMEOUT_SECONDS=120

# OAuth (Google)
# Get these from https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-client-id
