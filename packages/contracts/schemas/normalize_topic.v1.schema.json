{
  "$defs": {
    "ArtifactMetadata": {
      "description": "Metadata attached to every LLM-generated artifact for auditing.",
      "properties": {
        "provider": {
          "enum": [
            "gemini",
            "claude",
            "zai",
            "local",
            "none"
          ],
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "prompt_version": {
          "description": "e.g., 'plan/v1'",
          "title": "Prompt Version",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "request_id": {
          "format": "uuid",
          "title": "Request Id",
          "type": "string"
        },
        "raw_output_hash": {
          "description": "SHA-256 hash of raw LLM response (64 hex chars)",
          "title": "Raw Output Hash",
          "type": "string"
        },
        "artifact_hash": {
          "description": "SHA-256 hash of validated JSON artifact (64 hex chars)",
          "title": "Artifact Hash",
          "type": "string"
        },
        "validation_retry_count": {
          "description": "Number of schema retries",
          "minimum": 0,
          "title": "Validation Retry Count",
          "type": "integer"
        }
      },
      "required": [
        "provider",
        "model",
        "prompt_version",
        "created_at",
        "request_id",
        "raw_output_hash",
        "artifact_hash",
        "validation_retry_count"
      ],
      "title": "ArtifactMetadata",
      "type": "object"
    }
  },
  "description": "Response from topic normalization.",
  "properties": {
    "topic_normalized": {
      "description": "Canonical form of the topic (lowercase with underscores)",
      "title": "Topic Normalized",
      "type": "string"
    },
    "domain_category": {
      "description": "The domain category for staleness determination",
      "enum": [
        "math",
        "cs",
        "networking",
        "cloud",
        "web",
        "ai",
        "general"
      ],
      "title": "Domain Category",
      "type": "string"
    },
    "staleness_policy": {
      "description": "How often cached plans for this topic should be checked",
      "enum": [
        "never",
        "7d",
        "14d",
        "30d",
        "90d",
        "annual"
      ],
      "title": "Staleness Policy",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata",
      "description": "LLM generation metadata"
    }
  },
  "required": [
    "topic_normalized",
    "domain_category",
    "staleness_policy",
    "metadata"
  ],
  "title": "NormalizeTopicResponse",
  "type": "object"
}
