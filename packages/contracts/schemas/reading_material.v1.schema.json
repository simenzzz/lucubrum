{
  "$defs": {
    "ArtifactMetadata": {
      "description": "Metadata attached to every LLM-generated artifact for auditing.",
      "properties": {
        "provider": {
          "enum": [
            "gemini",
            "claude",
            "zai",
            "local",
            "none"
          ],
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "prompt_version": {
          "description": "e.g., 'plan/v1'",
          "title": "Prompt Version",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "request_id": {
          "format": "uuid",
          "title": "Request Id",
          "type": "string"
        },
        "raw_output_hash": {
          "description": "SHA-256 hash of raw LLM response (64 hex chars)",
          "title": "Raw Output Hash",
          "type": "string"
        },
        "artifact_hash": {
          "description": "SHA-256 hash of validated JSON artifact (64 hex chars)",
          "title": "Artifact Hash",
          "type": "string"
        },
        "validation_retry_count": {
          "description": "Number of schema retries",
          "minimum": 0,
          "title": "Validation Retry Count",
          "type": "integer"
        }
      },
      "required": [
        "provider",
        "model",
        "prompt_version",
        "created_at",
        "request_id",
        "raw_output_hash",
        "artifact_hash",
        "validation_retry_count"
      ],
      "title": "ArtifactMetadata",
      "type": "object"
    },
    "ReadingMaterialSection": {
      "description": "A single section of reading material.",
      "properties": {
        "heading": {
          "description": "Section heading",
          "maxLength": 50,
          "minLength": 5,
          "title": "Heading",
          "type": "string"
        },
        "content": {
          "description": "Section content in markdown",
          "minLength": 50,
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "heading",
        "content"
      ],
      "title": "ReadingMaterialSection",
      "type": "object"
    }
  },
  "description": "LLM-generated reading material from video transcripts.",
  "properties": {
    "schema_version": {
      "const": "reading_material.v1",
      "default": "reading_material.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "plan_id": {
      "description": "Associated plan UUID",
      "title": "Plan Id",
      "type": "string"
    },
    "node_id": {
      "description": "Associated node ID within the plan",
      "title": "Node Id",
      "type": "string"
    },
    "sections": {
      "description": "1-8 sections of reading material",
      "items": {
        "$ref": "#/$defs/ReadingMaterialSection"
      },
      "maxItems": 8,
      "minItems": 1,
      "title": "Sections",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    }
  },
  "required": [
    "plan_id",
    "node_id",
    "sections",
    "metadata"
  ],
  "title": "ReadingMaterial",
  "type": "object"
}
