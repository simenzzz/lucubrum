{
  "$defs": {
    "ArtifactMetadata": {
      "description": "Metadata attached to every LLM-generated artifact for auditing.",
      "properties": {
        "provider": {
          "enum": [
            "gemini",
            "claude"
          ],
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "prompt_version": {
          "description": "e.g., 'plan/v1'",
          "title": "Prompt Version",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "request_id": {
          "format": "uuid",
          "title": "Request Id",
          "type": "string"
        },
        "raw_output_hash": {
          "description": "SHA-256 hash of raw LLM response (64 hex chars)",
          "title": "Raw Output Hash",
          "type": "string"
        },
        "artifact_hash": {
          "description": "SHA-256 hash of validated JSON artifact (64 hex chars)",
          "title": "Artifact Hash",
          "type": "string"
        },
        "validation_retry_count": {
          "description": "Number of schema retries (0-2)",
          "maximum": 2,
          "minimum": 0,
          "title": "Validation Retry Count",
          "type": "integer"
        }
      },
      "required": [
        "provider",
        "model",
        "prompt_version",
        "created_at",
        "request_id",
        "raw_output_hash",
        "artifact_hash",
        "validation_retry_count"
      ],
      "title": "ArtifactMetadata",
      "type": "object"
    }
  },
  "description": "Result of checking if cached content is stale.",
  "properties": {
    "schema_version": {
      "const": "staleness_result.v1",
      "default": "staleness_result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "cache_key": {
      "description": "Cache key being checked",
      "title": "Cache Key",
      "type": "string"
    },
    "is_stale": {
      "description": "Whether the content is considered stale",
      "title": "Is Stale",
      "type": "boolean"
    },
    "contradiction_rate": {
      "description": "Rate of contradictions found (0.0-1.0)",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Contradiction Rate",
      "type": "number"
    },
    "stale_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "If stale, explanation why",
      "title": "Stale Reason"
    },
    "sources_checked": {
      "description": "List of sources that were checked",
      "items": {
        "type": "string"
      },
      "title": "Sources Checked",
      "type": "array"
    },
    "contradictions_found": {
      "description": "Specific contradictions discovered",
      "items": {
        "type": "string"
      },
      "title": "Contradictions Found",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    }
  },
  "required": [
    "cache_key",
    "is_stale",
    "contradiction_rate",
    "metadata"
  ],
  "title": "StalenessResult",
  "type": "object"
}
