{
  "$defs": {
    "TranscriptSegment": {
      "description": "A single timed segment of transcript.",
      "properties": {
        "start_seconds": {
          "description": "Start time in seconds",
          "minimum": 0,
          "title": "Start Seconds",
          "type": "number"
        },
        "duration_seconds": {
          "description": "Segment duration in seconds",
          "minimum": 0,
          "title": "Duration Seconds",
          "type": "number"
        },
        "text": {
          "description": "Transcript text for this segment",
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "start_seconds",
        "duration_seconds",
        "text"
      ],
      "title": "TranscriptSegment",
      "type": "object"
    }
  },
  "description": "Raw transcript data for a YouTube video.",
  "properties": {
    "schema_version": {
      "const": "transcript.v1",
      "default": "transcript.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "video_id": {
      "description": "YouTube video ID",
      "maxLength": 11,
      "minLength": 11,
      "title": "Video Id",
      "type": "string"
    },
    "language": {
      "default": "en",
      "description": "Transcript language code",
      "title": "Language",
      "type": "string"
    },
    "segments": {
      "description": "Timed transcript segments",
      "items": {
        "$ref": "#/$defs/TranscriptSegment"
      },
      "title": "Segments",
      "type": "array"
    },
    "full_text": {
      "description": "Concatenated transcript text",
      "title": "Full Text",
      "type": "string"
    },
    "duration_seconds": {
      "description": "Total video duration in seconds",
      "minimum": 0,
      "title": "Duration Seconds",
      "type": "integer"
    },
    "fetch_source": {
      "description": "Source of the transcript data",
      "enum": [
        "youtube_transcript_api",
        "youtube_api",
        "manual"
      ],
      "title": "Fetch Source",
      "type": "string"
    }
  },
  "required": [
    "video_id",
    "segments",
    "full_text",
    "duration_seconds",
    "fetch_source"
  ],
  "title": "Transcript",
  "type": "object"
}
