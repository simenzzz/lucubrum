{
  "$defs": {
    "ArtifactMetadata": {
      "description": "Metadata attached to every LLM-generated artifact for auditing.",
      "properties": {
        "provider": {
          "enum": [
            "gemini",
            "claude"
          ],
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "prompt_version": {
          "description": "e.g., 'plan/v1'",
          "title": "Prompt Version",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "request_id": {
          "format": "uuid",
          "title": "Request Id",
          "type": "string"
        },
        "raw_output_hash": {
          "description": "SHA-256 hash of raw LLM response (64 hex chars)",
          "title": "Raw Output Hash",
          "type": "string"
        },
        "artifact_hash": {
          "description": "SHA-256 hash of validated JSON artifact (64 hex chars)",
          "title": "Artifact Hash",
          "type": "string"
        },
        "validation_retry_count": {
          "description": "Number of schema retries (0-2)",
          "maximum": 2,
          "minimum": 0,
          "title": "Validation Retry Count",
          "type": "integer"
        }
      },
      "required": [
        "provider",
        "model",
        "prompt_version",
        "created_at",
        "request_id",
        "raw_output_hash",
        "artifact_hash",
        "validation_retry_count"
      ],
      "title": "ArtifactMetadata",
      "type": "object"
    }
  },
  "description": "Result of validating a video against a learning topic.",
  "properties": {
    "schema_version": {
      "const": "video_validation.v1",
      "default": "video_validation.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "video_id": {
      "description": "YouTube video ID",
      "maxLength": 11,
      "minLength": 11,
      "title": "Video Id",
      "type": "string"
    },
    "plan_id": {
      "description": "Associated plan UUID",
      "format": "uuid",
      "title": "Plan Id",
      "type": "string"
    },
    "node_id": {
      "description": "Associated node ID within the plan",
      "title": "Node Id",
      "type": "string"
    },
    "is_relevant": {
      "description": "Whether the video is relevant to the node",
      "title": "Is Relevant",
      "type": "boolean"
    },
    "relevance_score": {
      "description": "Relevance score from 0.0 to 1.0",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Relevance Score",
      "type": "number"
    },
    "matched_objectives": {
      "description": "Which node objectives this video covers",
      "items": {
        "type": "string"
      },
      "title": "Matched Objectives",
      "type": "array"
    },
    "rejection_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "If not relevant, explanation why",
      "title": "Rejection Reason"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    }
  },
  "required": [
    "video_id",
    "plan_id",
    "node_id",
    "is_relevant",
    "relevance_score",
    "metadata"
  ],
  "title": "VideoValidation",
  "type": "object"
}
